{
  "name": "serika-desktop",
  "version": "1.0.0",
  "description": "Serika streaming desktop app with QR and password login",
  "author": "Serika",
  "license": "MIT",
  "main": "src/main.js",
  "scripts": {
    "start": "bun run electron .",
    "dev": "bun run electron . --dev",
    "dist": "bun run electron-builder",
    "dist:win": "bun run electron-builder --win",
    "dist:mac": "bun run electron-builder --mac",
    "dist:linux": "bun run electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "moe.serika.desktop",
    "productName": "Serika",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*"
    ],
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.entertainment",
      "icon": "build/icon.png"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "AudioVideo",
      "icon": "build/icon.png"
    }
  }
}
